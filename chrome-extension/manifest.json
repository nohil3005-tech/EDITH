{
  "manifest_version": 3,
  "name": "EDITH Freelancer Bridge",
  "version": "1.0.0",
  "description": "Bridges freelance platform (Upwork/Fiverr) notifications, messages, and contracts directly into EDITH.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.upwork.com/*",
    "https://*.fiverr.com/*",
    "http://localhost:3001/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.upwork.com/*",
        "https://*.fiverr.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
