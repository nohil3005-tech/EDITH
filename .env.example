# ─── EDITH Complete — Root Environment Variables ─────────────
# Used by docker-compose.yml
# Copy to .env: cp .env.example .env

# Security
API_KEY=edith-secret-key-change-me

# AI — REQUIRED (free at https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
DEFAULT_MODEL=deepseek/deepseek-chat
FALLBACK_MODEL=openai/gpt-4o-mini

# Supabase (optional — for auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGci...
SUPABASE_SERVICE_KEY=eyJhbGci...

# Payments (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...

# Email (optional — free at https://resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=EDITH <noreply@yourdomain.com>

# Storage: local | supabase | s3 | r2
STORAGE_PROVIDER=local

# App
FRONTEND_URL=http://localhost:3000
NODE_ENV=production
