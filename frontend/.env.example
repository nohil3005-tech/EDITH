# ─── EDITH Frontend Environment Variables ─────────────────────
# Copy this to .env and fill in your values.
# The .env file is already pre-filled for local development.

# Backend connection (REQUIRED)
VITE_API_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001
VITE_API_KEY=edith-dev-key

# Supabase (for auth page only — optional if you skip auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_PROJECT_ID=your-project-id

# SSR / Server functions (same as VITE_ but without prefix)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
